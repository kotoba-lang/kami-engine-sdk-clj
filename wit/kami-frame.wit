// kami:engine/frame — proposed ADDITIVE interface for the Clojure SDK.
//
// The legacy world (../../wit/kami-game/world.wit) is per-call immediate-mode
// (draw-mesh per object). The clj SDK needs a frame-submit + resource-registration
// surface so the whole engine loop can live host-side and treat the GPU as a
// service (ARCHITECTURE.md §7, §8b).
//
// MERGE GATE: adding this to kami-render is an *additive* engine change →
// engine owner review. It does NOT modify bootstrap, Backends/Limits, or existing
// scene_pipelines, so no kami-app-{game} impact note is required (per
// ../../ARCHITECTURE.md change-approval table).

package kami:engine@1.0.0;

interface frame {
    // --- resource registration (upload once, keyed by asset id) ---

    // Upload a mesh under `id`. Idempotent on identical bytes. Returns a handle.
    register-mesh: func(id: string, vertices: list<f32>, indices: list<u32>) -> u32;

    // Upload material params (flat f32 vector, layout per pipeline) under `id`.
    register-material: func(id: string, params: list<f32>) -> u32;

    // Register clj-authored WGSL (from kami.wgsl/emit) as a pipeline under `id`.
    // `layout` is a serialized bind-group plan (edn/json). Returns a pipeline handle.
    register-shader: func(id: string, wgsl: string, layout: string) -> u32;

    // --- per-frame submission (retained-by-id, immediate-by-frame) ---

    // Submit one frame. `meta` is the small JSON draw-table from kami.ipc/pack's
    // :meta (frame number, clear colour, and per-draw {pipeline, mesh, material,
    // count} in column order). `ir` is the KAMI IPC columnar buffer: camera
    // matrices (column 0) + per-draw instance mat4 columns (columns 1..n). The
    // heavy matrices stay zero-copy in the buffer; only the tiny references travel
    // as JSON. Implemented by kami-clj-host::host::KamiCljHost::submit_frame.
    submit-frame: func(meta: string, ir-ptr: u32, ir-len: u32);

    // Surface resize (depth target realloc, swapchain reconfigure).
    resize: func(width: u32, height: u32);
}

// What the Clojure-SDK host runtime needs kami-render to expose. Reuses the
// legacy input/time imports; adds the `frame` export above.
world kami-clj-host {
    export frame;
    import kami:engine/input@1.0.0;
    import kami:engine/time@1.0.0;

    export memory;
    export cabi_realloc: func(old-ptr: s32, old-size: s32, align: s32, new-size: s32) -> s32;
}
